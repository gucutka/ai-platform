    },
    "issue_id": {
      "type": "integer"
    },
    "tasks": {
      "type": "array"
    },
    "branch_name": {
      "type": "string"
    },
    "token_budget_reserved": {
      "type": "integer"
    },
    "runtime": {
      "type": "string"
    }
  },
  "additionalProperties": true
}