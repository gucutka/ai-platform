{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-platform/contracts/ProductSpec.v1.json",
  "title": "ProductSpec",
  "type": "object",
  "required": [
    "contract",
    "version",
    "issue_id",
    "feature_summary",
    "dependencies"
  ],
  "properties": {
    "contract": {
      "const": "ProductSpec"
    },
    "version": {
      "const": "1.0"
    },
    "issue_id": {
      "type": "integer"
    },
    "feature_summary": {
      "type": "string"
    },
    "dependencies": {
      "type": "array"
    },
    "acceptance_criteria_mapped": {
      "type": "boolean"
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": true
}