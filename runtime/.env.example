# Copy to .env and fill in (do NOT commit .env).
# Auto-loaded by the CLI at startup (src/load-env.ts); shell variables take priority.
# Quote values that contain spaces (e.g. paths).
# The runtime RUNS FROM ai-platform but OPERATES ON the client repo:
#   - PROJECT_DIR        → filesystem of the client repo (knowledge, manifest)
#   - GITHUB_REPOSITORY  → GitHub API target (issues / PRs) = the client repo

# ============================================================
# ALWAYS REQUIRED (all agents, incl. Slack-only conversation)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
CLAUDE_RUNTIME=cloud-agents

PLATFORM_ROOT=/absolute/path/to/ai-platform
PROJECT_DIR=/absolute/path/to/client-repo

# ============================================================
# SLACK (conversation agents: intake / discovery / architecture / feature-intake)
# ============================================================
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SIGNING_SECRET=REPLACE_ME
# Optional: bot user id (U...) from auth.test — extra guard against reply loops
# SLACK_BOT_USER_ID=U0123456789
# Optional: hosted Slack MCP (https://mcp.slack.com/mcp) needs user OAuth (xoxp-), not xoxb-.
# Without it, agents reply via emit_channel_turn + chat.postMessage (recommended for bot apps).
# SLACK_MCP_OAUTH_TOKEN=xoxp-REPLACE_ME

# ============================================================
# GITHUB — only for feature-intake (create Issue) + Issue→PR pipeline.
# NOT needed for intake/discovery/architecture Slack chat.
# GITHUB_TOKEN = a PAT with access to the CLIENT repo (issues+PR write).
# ============================================================
GITHUB_TOKEN=ghp_REPLACE_ME
GITHUB_REPOSITORY=your-org/client-repo

# ============================================================
# NOT needed locally
# ------------------------------------------------------------
# GH_PAT belongs in the CLIENT repo's GitHub Actions secrets — it is the
# checkout token to pull a SEPARATE ai-platform repo. Locally ai-platform is a
# sibling folder, so no GH_PAT here. (Runtime fallback: App → GH_PAT → GITHUB_TOKEN.)
# GH_PAT=
#
# GitHub App (production alternative to a PAT):
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_INSTALLATION_ID=

# ============================================================
# OPTIONAL — webhook / notifications (non-Slack channels)
# ============================================================
# CHANNEL_WEBHOOK_SECRET=
# CHANNEL_NOTIFY_WEBHOOK_URL=
# CHANNEL_NOTIFY_WEBHOOK_SECRET=
# AI_PLATFORM_WEBHOOK_SECRET=
