{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeChanges",
  "description": "Implement agent output before PR exists",
  "type": "object",
  "required": ["contract", "version", "issue_id", "branch", "files"],
  "properties": {
    "contract": { "const": "CodeChanges" },
    "version": { "const": "1.0" },
    "issue_id": { "type": "integer" },
    "branch": { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "content"],
        "properties": {
          "path": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    },
    "summary": { "type": "string" },
    "pr_description": {
      "type": "object",
      "required": ["summary", "changes", "testing"],
      "properties": {
        "summary": { "type": "string" },
        "changes": { "type": "string" },
        "testing": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "agent_run_id": { "type": "string" }
  },
  "additionalProperties": true
}
